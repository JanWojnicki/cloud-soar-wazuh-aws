<group name="local,syslog,sshd,">
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>
</group>

<group name="amazon,aws,">
  <rule id="100010" level="3">
    <if_group>amazon</if_group>
    <match>REJECT</match>
    <description>AWS VPC Flow: Odrzucono pakiet sieciowy</description>
  </rule>

  <rule id="100002" level="12">
    <if_sid>80202</if_sid>
    <field name="aws.eventName">AuthorizeSecurityGroupIngress</field>
    <match>0.0.0.0/0</match>
    <description>AWS ALARM KRYTYCZNY: Wykryto otwarcie portow na caly swiat!</description>
    <mitre>
      <id>T1562.007</id>
    </mitre>
  </rule>

  <rule id="100003" level="12" frequency="3" timeframe="300">
    <if_matched_sid>100010</if_matched_sid>
    <same_field>aws.srcaddr</same_field>
    <description>AWS NETWORK ALARM: Wykryto aktywne skanowanie portow (Nmap)!</description>
    <mitre>
      <id>T1595.001</id>
    </mitre>
  </rule>

  <rule id="100011" level="3">
    <if_group>amazon</if_group>
    <field name="aws.dstport">^22$</field>
    <description>AWS VPC Flow: Zarejestrowano ruch na porcie 22 (SSH)</description>
  </rule>

  <rule id="100004" level="13" timeframe="600">
    <if_sid>100011</if_sid>
    <if_matched_sid>100003</if_matched_sid>
    <same_field>aws.srcaddr</same_field>
    <description>ALARM KRYTYCZNY: Skoordynowany atak! Wykryto rekonesans i uderzenie w SSH!</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>
</group>
